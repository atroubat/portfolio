---
// src/components/BaseHead.astro - VERSION OPTIMISÉE SEO
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
}

const {
  title = "Alexandre Troubat - SRE DevOps Limoges | Infrastructure Cloud & Monitoring",
  description = "Site Reliability Engineer chez Equativ à Limoges. Expert DevOps, infrastructure cloud, Grafana, Prometheus. Spécialiste monitoring haute disponibilité. Consultant SRE Nouvelle-Aquitaine.",
  image = "/nano.png",
  canonical = new URL(Astro.url.pathname, Astro.site).href,
} = Astro.props;

const imageUrl = new URL(image, Astro.url.origin).href;
---

<!-- Global Metadata OPTIMISÉ -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon-dark.svg" media="(prefers-color-scheme: dark)" />
<link rel="icon" type="image/svg+xml" href="/favicon-light.svg" media="(prefers-color-scheme: light)" />
<link rel="icon" type="image/x-icon" href="/favicon-light.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Font preloads (keep existing) -->
<link rel="preload" href="/_astro/inter-latin-400-normal.C38fXH4l.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/_astro/inter-latin-600-normal.LgqL8muc.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/_astro/lora-latin-400-normal.DnxXpLNu.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/_astro/lora-latin-600-normal.B-3RcLOQ.woff2" as="font" type="font/woff2" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonical} />

<!-- Primary Meta Tags OPTIMISÉS -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- MOTS-CLÉS STRATÉGIQUES -->
<meta name="keywords" content="SRE Limoges, DevOps Limoges, Site Reliability Engineer, Infrastructure cloud, Grafana expert, Prometheus monitoring, DevOps consultant Nouvelle-Aquitaine, Spécialiste monitoring haute disponibilité, Terraform Ansible, AWS GCP, Observabilité, SLO SLI, Microservices, CI CD, Docker, Alexandre Troubat, Equativ" />

<!-- GÉOLOCALISATION -->
<meta name="geo.region" content="FR-87" />
<meta name="geo.placename" content="Limoges, Nouvelle-Aquitaine, France" />
<meta name="geo.position" content="45.8336;1.2611" />
<meta name="ICBM" content="45.8336, 1.2611" />

<!-- LANGUE ET LOCALISATION -->
<meta name="language" content="French" />
<meta name="author" content="Alexandre Troubat" />
<meta name="robots" content="index, follow" />

<!-- Open Graph / Facebook OPTIMISÉ -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="fr_FR" />
<meta property="og:site_name" content="Alexandre Troubat - SRE DevOps" />

<!-- Twitter OPTIMISÉ -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonical} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:creator" content="@atroubat" />

<!-- Schema.org JSON-LD COMPLET -->
<script type="application/ld+json">
