---
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@consts";

// SEO OPTIMISÉ
const title = "Alexandre Troubat - SRE DevOps Limoges | Infrastructure Cloud & Monitoring";
const description = "Site Reliability Engineer chez Equativ à Limoges. Expert DevOps, infrastructure cloud, Grafana, Prometheus. Spécialiste monitoring haute disponibilité. Consultant SRE Nouvelle-Aquitaine.";

const experiences = [
  {
    role: "Site Reliability Engineer",
    company: "Equativ",
    period: "2019 — Présent",
    tasks: [
      "Infrastructure mondiale haute disponibilité",
      "Architecture microservices — Kafka, Kubernetes, Rancher",
      "CI/CD GitLab — déploiement et tests automatisés",
      "Monitoring — Grafana, Prometheus, Alertmanager",
      "Validation technique des mises en production",
    ],
  },
  {
    role: "Administrateur Système & Réseaux",
    company: "Célios Conseils",
    period: "2017 — 2019",
    tasks: [
      "Plan de sécurité informatique du Groupe",
      "Gestion d'incidents et résolution N1",
      "Supervision des opérations d'exploitation",
    ],
  },
];

const stackCategories = [
  {
    title: "Infrastructure",
    items: ["GNU/Linux (Debian/Ubuntu)", "Terraform", "Ansible", "HAProxy", "Teleport", "PostgreSQL / MySQL", "Git"],
  },
  {
    title: "Cloud & Kubernetes",
    items: ["Kubernetes (EKS, GKE, on-prem)", "Rancher", "ArgoCD", "AWS (EC2, RDS, S3, Route53)", "GCP (GKE, CloudSQL, GCS)"],
  },
  {
    title: "Observabilité",
    items: ["Prometheus / Thanos", "Grafana / Loki", "AlertManager", "SLO / SLI / Error Budgets"],
  },
  {
    title: "Intelligence Artificielle",
    items: ["Claude Code via OpenClaw", "Développement assisté par IA", "Automatisation de workflows", "Solutions sur-mesure"],
  },
];

const formations = [
  { year: "2018", title: "Master — Manager de SI & Infrastructures", school: "3iL Ingénieurs" },
  { year: "2016", title: "Bachelor — Concepteur de SI, option Réseau", school: "3iL Ingénieurs" },
  { year: "2015", title: "BTS SIO — SISR", school: "Lycée Beaupeyrat" },
];
---

<PageLayout title={title} description={description}>

  <!-- HERO -->
  <section class="min-h-screen flex items-center relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-moon-950 via-moon-950 to-violet-950/30"></div>
    <div class="absolute top-1/3 right-1/4 w-[500px] h-[500px] bg-violet-500/[0.03] rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/3 left-1/6 w-72 h-72 bg-pink-500/[0.02] rounded-full blur-3xl"></div>
    
    <div class="relative z-10 max-w-5xl mx-auto px-6 py-20 w-full">
      <div class="space-y-8">
        <div class="flex items-center gap-3 text-accent-violet/80 text-sm font-mono animate">
          <span class="w-8 h-px bg-accent-violet/40"></span>
          <span>SRE · Limoges</span>
        </div>
        
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white/95 leading-[1.05] animate" style="animation-delay: 100ms">
          Alexandre<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-violet to-accent-pink">Troubat</span>
        </h1>
        
        <p class="text-lg text-slate-400 max-w-xl animate" style="animation-delay: 200ms">
          <strong>Site Reliability Engineer chez Equativ</strong> basé à <strong>Limoges, Nouvelle-Aquitaine</strong>.<br/>
          Expert <strong>DevOps</strong>, <strong>infrastructure cloud</strong>, <strong>monitoring Grafana/Prometheus</strong>.
        </p>

      </div>
    </div>
  </section>

  <!-- EXPERIENCE — violet -->
  <section class="py-28 relative" id="experience">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-violet-950/[0.04] to-transparent"></div>
    <div class="relative max-w-5xl mx-auto px-6">
      <div class="flex items-center gap-4 mb-12 animate">
        <span class="text-violet-400/60 font-mono text-sm">01</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white/90">Expérience</h2>
      </div>

      <div class="space-y-14">
        {experiences.map((exp, i) => (
          <div class="group relative pl-8 border-l border-moon-800 hover:border-violet-400/30 transition-colors duration-500 animate" style={`animation-delay: ${i * 100}ms`}>
            <div class="absolute -left-[5px] top-1 w-2.5 h-2.5 rounded-full bg-moon-800 group-hover:bg-violet-400/60 transition-colors duration-500"></div>
            
            <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-1">
              <h3 class="text-lg font-semibold text-white/90">{exp.role}</h3>
              <span class="text-violet-400/70 font-mono text-sm">{exp.company}</span>
            </div>
            <div class="text-sm text-slate-500 mb-4 font-mono">{exp.period}</div>
            <ul class="space-y-1.5">
              {exp.tasks.map(task => (
                <li class="flex gap-3 text-slate-400 text-sm">
                  <span class="text-violet-400/40 mt-0.5">›</span>
                  <span>{task}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPÉTENCES — rose -->
  <section class="py-28 relative" id="skills">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-pink-950/[0.04] to-transparent"></div>
    <div class="relative max-w-5xl mx-auto px-6">
      <div class="flex items-center gap-4 mb-12 animate">
        <span class="text-pink-400/60 font-mono text-sm">02</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white/90">Compétences</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-12">
        {stackCategories.map((cat, i) => (
          <div class="animate" style={`animation-delay: ${i * 80}ms`}>
            <h3 class="text-sm font-mono text-pink-400/50 uppercase tracking-wider mb-5">{cat.title}</h3>
            <ul class="space-y-2.5">
              {cat.items.map(item => (
                <li class="text-slate-300 flex items-center gap-3">
                  <span class="w-1 h-1 rounded-full bg-pink-400/30 flex-shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FORMATION — bleu -->
  <section class="py-28 relative" id="formation">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-950/[0.04] to-transparent"></div>
    <div class="relative max-w-5xl mx-auto px-6">
      <div class="flex items-center gap-4 mb-12 animate">
        <span class="text-blue-400/60 font-mono text-sm">03</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white/90">Formation</h2>
      </div>

      <div class="space-y-6">
        {formations.map((f, i) => (
          <div class="flex gap-6 items-baseline animate" style={`animation-delay: ${i * 80}ms`}>
            <span class="text-sm font-mono text-blue-400/30 w-12 flex-shrink-0">{f.year}</span>
            <div>
              <h3 class="text-base font-medium text-white/85">{f.title}</h3>
              <p class="text-sm text-slate-500">{f.school}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Langues -->
      <div class="mt-14 animate">
        <h3 class="text-sm font-mono text-blue-400/50 uppercase tracking-wider mb-5">Langues</h3>
        <div class="flex gap-8">
          <div class="flex items-center gap-4">
            <span class="text-sm font-medium text-white/80">Français</span>
            <div class="flex gap-1">
              <span class="w-2 h-2 rounded-full bg-blue-400/60"></span>
              <span class="w-2 h-2 rounded-full bg-blue-400/60"></span>
              <span class="w-2 h-2 rounded-full bg-blue-400/60"></span>
              <span class="w-2 h-2 rounded-full bg-blue-400/60"></span>
              <span class="w-2 h-2 rounded-full bg-blue-400/60"></span>
            </div>
            <span class="text-xs text-slate-600">natif</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm font-medium text-white/80">English</span>
            <div class="flex gap-1">
              <span class="w-2 h-2 rounded-full bg-blue-400/60"></span>
              <span class="w-2 h-2 rounded-full bg-blue-400/60"></span>
              <span class="w-2 h-2 rounded-full bg-blue-400/60"></span>
              <span class="w-2 h-2 rounded-full bg-blue-400/60"></span>
              <span class="w-2 h-2 rounded-full bg-blue-400/20"></span>
            </div>
            <span class="text-xs text-slate-600">TOEIC 895</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT — violet -->
  <section class="py-28 relative" id="contact">
    <div class="max-w-5xl mx-auto px-6">
      <div class="flex items-center gap-4 mb-6 animate">
        <span class="text-accent-violet/60 font-mono text-sm">04</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white/90">Contact</h2>
      </div>
      <p class="text-slate-400 mb-8 animate">
        Disponible pour échanger.
      </p>
      <div class="flex animate">
        <a href="mailto:atroubat@atroubat.fr" class="px-6 py-3 bg-accent-violet/15 hover:bg-accent-violet/25 text-accent-violet border border-accent-violet/20 hover:border-accent-violet/40 font-medium rounded-lg transition-all duration-300">
          atroubat@atroubat.fr
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="py-8 border-t border-moon-900">
    <div class="max-w-5xl mx-auto px-6 flex flex-wrap justify-between items-center gap-4">
      <span class="text-xs text-moon-600">© 2026 Alexandre Troubat</span>
      <div class="flex gap-6 text-xs text-moon-600">
        <a href="https://github.com/atroubat" target="_blank" rel="noopener" class="hover:text-slate-400 transition-colors">GitHub</a>
        <a href="https://www.linkedin.com/in/alexandre-troubat-834661154" target="_blank" rel="noopener" class="hover:text-slate-400 transition-colors">LinkedIn</a>
      </div>
    </div>
  </footer>

</PageLayout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('show');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.animate').forEach(el => observer.observe(el));
</script>
