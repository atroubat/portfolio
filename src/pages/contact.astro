---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import siteConfig from '@/config/site.config';
import { resolveSocialLinks } from '@/lib/utils';

const socialLinks = resolveSocialLinks(siteConfig.socialLinks);
---

<PageLayout
  title={`Contact — ${siteConfig.name}`}
  description="Disponible pour échanger — email ou LinkedIn."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="mail" size="sm" />
      Contact
    </Badge>

    <h1 slot="title">
      Disponible pour <span class="text-brand-500">échanger.</span>
    </h1>

    <p slot="description">
      Une question technique, une opportunité, ou juste un bonjour — n'hésitez pas.
    </p>
  </Hero>

  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-2xl px-6 flex flex-col gap-4" data-reveal>

      <a href={`mailto:${siteConfig.email}`} class="block group">
        <Card hover padding="lg">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="mail" size="md" />
            </div>
            <div class="min-w-0 flex-1">
              <p class="font-semibold text-foreground">Email</p>
              <p class="text-sm text-foreground-muted">{siteConfig.email}</p>
            </div>
            <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
          </div>
        </Card>
      </a>

      {socialLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer" class="block group">
          <Card hover padding="lg">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                <Icon name={link.icon} size="md" />
              </div>
              <div class="min-w-0 flex-1">
                <p class="font-semibold text-foreground">{link.label}</p>
                <p class="text-sm text-foreground-muted truncate">{link.href.replace(/^https?:\/\/(www\.)?/, '')}</p>
              </div>
              <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
            </div>
          </Card>
        </a>
      ))}

      <Card padding="lg" class="bg-brand-500/5 border-brand-500/20">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
            <Icon name="map-pin" size="md" />
          </div>
          <div>
            <p class="font-semibold text-foreground">{siteConfig.address?.city}</p>
            <p class="text-sm text-foreground-muted">{siteConfig.address?.state}, {siteConfig.address?.country}</p>
          </div>
        </div>
      </Card>

    </div>
  </section>
</PageLayout>
