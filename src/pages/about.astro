---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import TypingEffect from '@/components/ui/TypingEffect.astro';
import TechStack from '@/components/landing/TechStack.astro';
import siteConfig from '@/config/site.config';

const location = siteConfig.address?.city
  ? `${siteConfig.address.city}${siteConfig.address.country ? `, ${siteConfig.address.country}` : ''}`
  : null;
---
<PageLayout
  title={`À propos — ${siteConfig.name}`}
  description="Site Reliability Engineer dans l'équipe Platform d'Equativ. Infrastructure cloud, Kubernetes, observabilité et automatisation GitOps."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="user" size="sm" />
      À propos
    </Badge>
    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">Alexandre Troubat —</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)]">
        <TypingEffect words={["Site Reliability Engineer", "DevOps Engineer", "Infrastructure Architect", "Kubernetes Operator", "Grafana Enthusiast", "Claude Code User"]} />
      </span>
    </h1>

    <p slot="description">
      SRE dans l'équipe Platform d'Equativ, à Limoges. Arrivé en 2019 (ex-DynAdmic), je suis passé de l'IT à l'infrastructure puis au SRE — systèmes distribués à l'échelle mondiale, fiabilité, automatisation et observabilité.
    </p>
  </Hero>
  <!-- Expérience -->
  <section class="py-[var(--space-section-md)] bg-brand-500/8 dark:bg-background-secondary">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-12">
      <div class="flex flex-col items-center gap-6 text-center" data-reveal>
        <Badge variant="brand" pill>Parcours</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          De l'IT au SRE,<br /><span class="text-brand-500">à grande échelle</span>
        </h2>
      </div>
      <div class="grid gap-12 lg:grid-cols-2 items-start">
        <div class="flex flex-col gap-4" data-reveal>
          <p class="text-lg text-foreground-muted leading-relaxed">
            Arrivé chez <strong>DynAdmic</strong> (devenu <strong>Equativ</strong>) en 2019{location ? `, basé à ${location}` : ''}, je suis passé de l'IT à l'infrastructure, puis au SRE dans l'équipe Platform depuis 2024. Aujourd'hui, j'opère une infrastructure mondiale — microservices Kubernetes, déploiements multi-cloud AWS/GCP, et pipelines CI/CD GitLab.
          </p>
          <dl class="grid grid-cols-3 gap-4 mt-2">
            <div class="flex flex-col gap-1">
              <dt class="text-2xl md:text-3xl font-bold text-brand-500">2,5 M</dt>
              <dd class="text-xs text-foreground-muted leading-snug">requêtes/s sur EU, NA &amp; APAC</dd>
            </div>
            <div class="flex flex-col gap-1">
              <dt class="text-2xl md:text-3xl font-bold text-brand-500">4 500+</dt>
              <dd class="text-xs text-foreground-muted leading-snug">serveurs en exploitation</dd>
            </div>
            <div class="flex flex-col gap-1">
              <dt class="text-2xl md:text-3xl font-bold text-brand-500">30+</dt>
              <dd class="text-xs text-foreground-muted leading-snug">clusters Kubernetes actifs</dd>
            </div>
          </dl>
        </div>
        <div class="flex flex-col gap-4" data-reveal data-reveal-delay="1">
          <Card variant="elevated" hover>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="briefcase" size="md" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold tracking-wide text-foreground-muted mb-1">Janv. 2024 — Présent</p>
                <h3 class="text-base font-semibold text-foreground">Site Reliability Engineer — Équipe Platform, Equativ</h3>
                <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                  Gestion de flotte (Ansible/Git), GitOps Rancher/ArgoCD (~30 clusters), observabilité Prometheus/Thanos/Alertmanager, IaC Terraform sur GCP et AWS.
                </p>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <Badge size="sm" variant="brand">Kubernetes</Badge>
                  <Badge size="sm" variant="brand">Terraform</Badge>
                  <Badge size="sm" variant="brand">ArgoCD</Badge>
                </div>
              </div>
            </div>
          </Card>
          <Card variant="elevated" hover>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="server" size="md" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold tracking-wide text-foreground-muted mb-1">2022 — 2024</p>
                <h3 class="text-base font-semibold text-foreground">Infrastructure — Equativ (ex-DynAdmic)</h3>
                <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                  Gestion de l'infrastructure DynAdmic pendant la transition post-rachat. Mise en place de la plateforme de catégorisation d'URLs (microservices, Kafka, Kubernetes, CI/CD, monitoring).
                </p>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <Badge size="sm" variant="brand">Kafka</Badge>
                  <Badge size="sm" variant="brand">Kubernetes</Badge>
                  <Badge size="sm" variant="brand">CI/CD</Badge>
                </div>
              </div>
            </div>
          </Card>
          <Card variant="elevated" hover>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="terminal" size="md" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold tracking-wide text-foreground-muted mb-1">2019 — 2022</p>
                <h3 class="text-base font-semibold text-foreground">IT & Supervision — DynAdmic</h3>
                <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                  Supervision, maintenance, réinstallation de machines, gestion du support OVH, et support IT au quotidien.
                </p>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <Badge size="sm" variant="brand">Supervision</Badge>
                  <Badge size="sm" variant="brand">Linux</Badge>
                  <Badge size="sm" variant="brand">OVH</Badge>
                </div>
              </div>
            </div>
          </Card>
          <Card variant="elevated" hover>
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="shield" size="md" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold tracking-wide text-foreground-muted mb-1">2017 — 2019</p>
                <h3 class="text-base font-semibold text-foreground">Administrateur Système & Réseau — Célios Conseils</h3>
                <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                  Plan de sécurité informatique du groupe, gestion d'incidents, supervision des opérations.
                </p>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <Badge size="sm" variant="brand">Sécurité</Badge>
                  <Badge size="sm" variant="brand">Réseau</Badge>
                  <Badge size="sm" variant="brand">Linux</Badge>
                </div>
              </div>
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>
  <!-- Valeurs -->
  <section class="py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 text-center flex flex-col items-center gap-4" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Principes</Badge>
          <h2 class="font-display text-4xl font-bold text-foreground">
            Comment je travaille
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          Quelques principes que j'applique au quotidien.
        </p>
      </div>
      <div class="grid gap-8 md:grid-cols-3" data-reveal data-reveal-delay="1">
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="shield-check" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Reliability First</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                SLO, SLI, error budgets — la fiabilité se mesure. Je construis des systèmes qui tiennent leurs engagements en production.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="git-branch" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">GitOps & Automatisation</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Tout est code, tout est versionné. Infrastructure as Code, pipelines CI/CD, déploiements reproductibles.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="trending-down" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">FinOps</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                La performance n'a de sens que si elle est rentable. Optimisation des coûts cloud intégrée à chaque décision d'architecture.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>
  <!-- My Stack -->
  <TechStack
    badge="Stack & Outils"
    title="Mon Stack"
    description="Les outils avec lesquels je travaille au quotidien."
  />
</PageLayout>
