---
/**
 * PageLayout
 * Layout wrapper for standard content pages (non-landing)
 * Uses Header + Footer with content page configuration
 */
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  nofollow?: boolean;
  showScrollProgress?: boolean;
}

const { title, description, image, imageAlt, noindex, nofollow, showScrollProgress = false } = Astro.props;

---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  noindex={noindex}
  nofollow={nofollow}
>
  <Header
    slot="header"
    position="fixed"
    shape="bar"
    variant="solid"
    size="lg"
    showActiveState
    showCta={false}
    cta={{ label: 'Get in touch', href: '/contact' }}
    showScrollProgress={showScrollProgress}
  />

  <main class="min-h-screen pt-16">
    <slot />
  </main>

  <Footer
    slot="footer"
    layout="simple"
    hideLogo
    nav={[]}
    socialLinks={[
      { platform: 'github', href: 'https://github.com/atroubat', label: 'GitHub' },
      { platform: 'linkedin', href: 'https://www.linkedin.com/in/alexandre-troubat-834661154', label: 'LinkedIn' },
      { platform: 'mail', href: 'mailto:atroubat@atroubat.fr', label: 'Email' },
    ]}
    legalLinks={[{ label: 'Mentions légales', href: '/mentions-legales' }]}
  />
</BaseLayout>
